{
  "name": "@repo/elysia-grpc",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "rm -rf dist",
    "gen:proto": "protoc --ts_proto_out=. --ts_proto_opt=esModuleInterop=true,useOptionals=none,exportCommonSymbols=false,useExactTypes=false src/protos/*.proto"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.5.0",
    "@grpc/grpc-js": "^1.13.3",
    "@grpc/proto-loader": "^0.7.15",
    "elysia": "^1.3.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "protoc": "^1.1.3",
    "ts-proto": "^1.146.0"
  },
  "peerDependencies": {
    "elysia": ">=1.3.1"
  }
}
